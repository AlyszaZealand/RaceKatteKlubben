spring.application.name=RaceKatteKlubben
# Copy this file to application.properties and replace placeholders with your real DB credentials.
spring.datasource.url=jdbc:mysql://localhost:3306/racekatteklubben
spring.datasource.username=REPLACE_WITH_DB_USERNAME
spring.datasource.password=REPLACE_WITH_DB_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.sql.init.mode=never

spring.thymeleaf.cache=false

server.port=8080
